# Copie para `.env` e preencha. Na Vercel: Settings → Environment Variables (Production + Preview).

# --- Supabase (front; prefixo VITE_ obrigatório no Vite) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# URL pública do cockpit (sem barra final). Usada em redirects de signup/confirmação.
# Dev: http://localhost:8080 ou a porta que usar | Prod: https://heradg.digitalhera.com.br
VITE_APP_URL=

# No Supabase → Authentication → URL Configuration, adicione Redirect URLs:
#   {VITE_APP_URL}/welcome
#   {VITE_APP_URL}/reset-password
#   {VITE_APP_URL}/login

# --- Resend (NUNCA use VITE_ na API key) ---
# Chave re_... — só em backend (Vercel Function, Edge Function) ou guarde só no Supabase SMTP.
# Se usar Resend como SMTP do Supabase Auth, estes valores vão no Dashboard Supabase → Auth → SMTP, não no front.
RESEND_API_KEY=
# Endereço verificado no Resend (ex.: Hera DG <noreply@seudominio.com>)
RESEND_FROM_EMAIL=
# Nome amigável opcional (alguns SDKs usam; pode ficar igual ao prefixo do FROM)
RESEND_FROM_NAME=
